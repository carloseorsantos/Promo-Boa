# === API ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/promoboa
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_PORTAL_SECRET=change_me_portal_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=flyers

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Internal API key for notification endpoint
INTERNAL_API_KEY=change_me_internal_key

# === PORTAL ===
NEXT_PUBLIC_API_URL=http://localhost:3000/v1

# === MOBILE ===
EXPO_PUBLIC_API_URL=http://localhost:3000/v1
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
